generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(uuid())
  vkId            BigInt            @unique
  firstName       String?
  lastName        String?
  activeProgramId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  settings        UserSettings?
  stats           UserStats?
  progresses      ProgramProgress[]
  workoutLogs     WorkoutLog[]
}

model UserSettings {
  id                       String   @id @default(uuid())
  userId                   String   @unique
  restSeconds              Int      @default(60)
  autoFillTargetOnComplete Boolean  @default(true)
  theme                    String   @default("light")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserStats {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  xp                     Int      @default(0)
  rewardedAchievementIds Json
  pendingAchievementIds  Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgramProgress {
  id                 String   @id @default(uuid())
  userId             String
  programId          String
  level              Int
  startedAt          DateTime
  currentWeek        Int
  currentDay         Int
  completedWorkouts  Json
  failedWorkouts     Json
  finished           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
}

model WorkoutLog {
  id           String   @id @default(uuid())
  userId       String
  programId    String
  key          String
  week         Int
  day          Int
  planned      Json
  actual       Json
  plannedTotal Int
  actualTotal  Int
  success      Boolean
  completedAt  DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, programId])
}